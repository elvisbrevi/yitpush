<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Package as Tool -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>yp</ToolCommandName>

    <!-- Package Metadata -->
    <PackageId>YitPush</PackageId>
    <Version>1.4.0</Version>
    <Authors>Elvis Brevi</Authors>
    <Description>AI-powered git commit automation tool. Now with full Azure DevOps Task management and shorter 'yp' command.</Description>

    <!-- URLs and Repository -->
    <PackageProjectUrl>https://github.com/elvisbrevi/yitpush</PackageProjectUrl>
    <RepositoryUrl>https://github.com/elvisbrevi/yitpush</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <!-- Tags for discoverability -->
    <PackageTags>
      git;commit;ai;deepseek;automation;cli;tool;dotnet-tool;conventional-commits;chat;developer-tools</PackageTags>

    <!-- License -->
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <!-- README -->
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Additional Metadata -->
    <Copyright>Copyright (c) 2026 Elvis Brevi</Copyright>
    <PackageReleaseNotes>New: Command shortened to 'yp' for faster usage (yitpush still works via alias).
New: Full Azure DevOps Task Management (hu list, task show, task update).
New: Interactive and direct updates for Effort, Esfuerzo Real HH, Remaining Work, State and Comments.
New: Smart state validation and selection menus for Azure DevOps.
New: Integrated 'List all fields' tool for debugging work item technical names.
Improved: Faster navigation with 'Back' support in all interactive menus.
Improved: Sorting by ID descending (recency first) in all Azure DevOps lists.</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.54.0" />
    <PackageReference Include="TextCopy" Version="6.2.1" />
  </ItemGroup>

</Project>
